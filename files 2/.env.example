# ============================================================
# FILE: .env
# PURPOSE: Store secret keys and config — NEVER commit this
#          to GitHub. Add .env to your .gitignore file!
# ============================================================

# Your Google Gemini API key
# Get it free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Port the backend server runs on
PORT=5000

# Set to "development" locally, "production" on your server
NODE_ENV=development

# Your frontend URL (for CORS). During dev, this is Vite's dev server
FRONTEND_URL=http://localhost:5173
